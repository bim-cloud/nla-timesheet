{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/agent",
      "destination": "/agent.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/nla_agent.py",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"nla_agent.py\""
        }
      ]
    },
    {
      "source": "/NLA_Activity_Agent_Setup.bat",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"NLA_Activity_Agent_Setup.bat\""
        }
      ]
    },
    {
      "source": "/build_agent.bat",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment; filename=\"build_agent.bat\""
        }
      ]
    }
  ]
}
